PUBLIC_BASE_URL=https://pyhsics.lucasma.cc

GHCR_IMAGE=ghcr.io/pony-maggie/shared-physics-playground
APP_IMAGE_TAG=latest

SERVER_CONTAINER_NAME=shared-physics-server
WEB_CONTAINER_NAME=shared-physics-web
SERVER_HOST_BIND=172.17.0.1:2568
WEB_HOST_BIND=172.17.0.1:4174
SERVER_PORT=2567
WEB_PORT=4173

PORT=2567
PLAYGROUND_LOG_LEVEL=info
PLAYGROUND_LOG_PATH=/app-logs/server-events.log
PLAYGROUND_LOG_TO_STDOUT=true

PLAYGROUND_AI_MODE=live
PLAYGROUND_AI_VENDOR=google
PLAYGROUND_AI_MODEL=gemini-2.5-flash
PLAYGROUND_AI_LIVE_PROVIDER_ORDER=google,minimax
GOOGLE_API_KEY=your_google_api_key_here
PLAYGROUND_AI_MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
PLAYGROUND_AI_PROVIDER_TIMEOUT_MS=8000
PLAYGROUND_AI_BYPASS_ENABLED=true
PLAYGROUND_AI_CACHE_TTL_MS=3600000
PLAYGROUND_AI_CACHE_MAX_ENTRIES=256
PLAYGROUND_AI_PROMPT_VERSION=v1

PLAYGROUND_PRO_INTEREST_EMAIL=machengyu519@gmail.com

MAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@your-verified-domain.example
RESEND_FROM_NAME=physics-playground
